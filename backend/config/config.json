{
  "listeners": [{
    "address": "0.0.0.0",
    "port": 8080
  }],
  "app": {
    "document_root": "./frontend/dist",
    "file_types": ["html", "js", "css", "png", "jpg", "ico", "svg", "woff2"],
    "log": {
      "log_path": "./logs",
      "log_level": "INFO"
    },
    "db_clients": [{
      "name": "sqlite3",
      "rdbms": "sqlite3",
      "filename": "./data/sophon_stream.db"
    }],
    "threads_num": 4,
    "run_as_daemon": false
  },
  "ssl": {
    "cert": "",
    "key": ""
  },
  "jwt": {
    "secret": "sophon-stream-web-jwt-secret-change-in-production",
    "access_token_expire_seconds": 86400,
    "refresh_token_expire_seconds": 604800,
    "issuer": "sophon-stream-web"
  },
  "cors": {
    "allowed_origins": ["*"],
    "allowed_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "allowed_headers": ["Content-Type", "Authorization", "X-Requested-With"],
    "max_age": 86400
  },
  "sophon_stream": {
    "sdk_lib_path": "/opt/sophon-stream/lib",
    "sdk_config_path": "/opt/sophon-stream/config",
    "default_graph_config": {}
  },
  "monitor": {
    "broadcast_interval_ms": 2000,
    "max_ws_connections": 100
  }
}
